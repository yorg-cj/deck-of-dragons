# Copy this file to .env and fill in your keys.
# Never commit .env to version control.

# --- Required for Phase 1 bootstrap (used once) ---
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=

# --- Required for live news fetching ---
# Get from: open-platform.theguardian.com  (free, no credit card)
GUARDIAN_API_KEY=

# Get from: developer.nytimes.com  (free, no credit card)
NYT_API_KEY=

# Get from: worldnewsapi.com  (free, no credit card)
WORLDNEWS_API_KEY=
